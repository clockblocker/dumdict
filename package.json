{
	"name": "dumdict",
	"version": "0.1.0",
	"description": "Dictionary relations and storage helpers built on top of dumling.",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.0",
	"license": "MIT",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "bun run build:js && bun run build:types",
		"build:js": "rm -rf dist && bun build src/v1/index.ts --outfile dist/index.js --format esm --target node --packages external",
		"build:types": "bunx tsc -p tsconfig.build.json",
		"check": "bunx tsc -p tsconfig.json --noEmit",
		"generate:readme": "bun run generate-readme/generate-readme.ts",
		"prepack": "bun run generate:readme && bun run build",
		"test": "bun test",
		"test:external": "bun test tests/external",
		"test:internal": "bun test tests/internal"
	},
	"dependencies": {
		"dumling": "^0.1.4",
		"neverthrow": "^8.2.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@types/bun": "1.3.0",
		"@types/node": "^24.5.2",
		"typescript": "^5.9.3"
	}
}
